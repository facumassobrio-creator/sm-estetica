---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site.js';

const success = Astro.url.searchParams.get('success');

// IMPORTANTE PARA DESARROLLADOR:
// El formulario ya está conectado a Formspree con el endpoint: https://formspree.io/f/xpqypyng
// Email receptor: smesteticafgm@gmail.com
// Si Formspree requiere URL absoluta para _next en producción, cambia el value a: "https://sm-estetica.pages.dev/contacto?success=1"
---
<BaseLayout title="Contacto - SM Estética" description="Contactá SM Estética por WhatsApp, teléfono o email">
  <!-- Encabezado -->
  <section class="max-w-6xl mx-auto py-12 text-center fade-in">
    <h1 class="text-4xl md:text-5xl font-extrabold text-azul mb-2">Contacto</h1>
    <p class="text-lg text-azul/80">Estamos aquí para ayudarte, escríbenos o visita nuestras redes.</p>
  </section>

  <!-- Tarjetas de contacto -->
  <section class="max-w-6xl mx-auto py-12 grid grid-cols-1 md:grid-cols-2 gap-8 fade-in">
    <div class="bg-white rounded-xl shadow hover:shadow-lg transition-base p-6 flex flex-col items-center text-center gap-4 border border-celeste/40 slide-up">
      <div class="text-5xl">💬</div>
      <h3 class="text-xl font-semibold text-azul">WhatsApp</h3>
      <p class="text-text text-sm">{site.whatsapp}</p>
      <a href={`https://wa.me/${site.whatsapp.replace(/\D/g,'')}`} target="_blank" rel="noopener" class="btn btn-primary mt-2">Escribir por WhatsApp</a>
    </div>
    <div class="bg-white rounded-xl shadow hover:shadow-lg transition-base p-6 flex flex-col items-center text-center gap-4 border border-celeste/40 slide-up">
      <div class="text-5xl">📞</div>
      <h3 class="text-xl font-semibold text-azul">Teléfono</h3>
      <p class="text-text text-sm">{site.telefono}</p>
      <a href={`tel:${site.telefono.replace(/\D/g,'')}`} class="mt-2 px-6 py-2 rounded border border-azul text-azul font-semibold hover:bg-celeste transition-base focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja">Llamar</a>
    </div>
    <div class="bg-white rounded-xl shadow hover:shadow-lg transition-base p-6 flex flex-col items-center text-center gap-4 border border-celeste/40 slide-up">
      <div class="text-5xl">✉️</div>
      <h3 class="text-xl font-semibold text-azul">Email</h3>
      <p class="text-text text-sm">{site.email}</p>
      <a href={`mailto:${site.email}`} class="mt-2 px-6 py-2 rounded border border-azul text-azul font-semibold hover:bg-celeste transition-base focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja">Enviar email</a>
    </div>
    <div class="bg-white rounded-xl shadow hover:shadow-lg transition-base p-6 flex flex-col items-center text-center gap-4 border border-celeste/40 slide-up">
      <div class="text-5xl">📷</div>
      <h3 class="text-xl font-semibold text-azul">Instagram</h3>
      <p class="text-text text-sm">{site.instagram}</p>
      <a href={`https://instagram.com/${site.instagram.replace('@','')}`} target="_blank" rel="noopener" class="mt-2 px-6 py-2 rounded border border-azul text-azul font-semibold hover:bg-celeste transition-base focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja">Ver Instagram</a>
    </div>
  </section>

  <!-- Horario -->
  <section class="max-w-6xl mx-auto py-12 fade-in">
    <div class="bg-white rounded-xl border border-celeste/40 p-6 slide-up">
      <h3 class="text-xl font-semibold text-azul mb-2">Horario</h3>
      <p class="text-text text-sm">Lunes a Viernes 9:00 a 18:00 (horario placeholder)</p>
    </div>
  </section>

  <!-- Formulario -->
  <section class="max-w-6xl mx-auto py-12 fade-in">
    <h2 class="text-2xl font-bold text-azul mb-4 text-center">Dejanos tu consulta</h2>
    {success === '1' && (
      <div class="max-w-md mx-auto mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded">
        ✅ Consulta enviada correctamente. Nos comunicaremos a la brevedad.
      </div>
    )}
    <form action="https://formspree.io/f/xpqypyng" method="POST" class="max-w-md mx-auto flex flex-col gap-4 slide-up">
      <!-- Campo honeypot para protección anti-spam -->
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" />

      <!-- Campo _next para redirección -->
      <input type="hidden" name="_next" value="/contacto?success=1" />

      <div>
        <label for="nombre" class="block text-sm font-medium text-azul mb-1">Nombre</label>
        <input type="text" id="nombre" name="nombre" placeholder="Tu nombre completo" required autocomplete="name" class="w-full px-4 py-2 border border-celeste/40 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja" />
      </div>
      <div>
        <label for="telefono" class="block text-sm font-medium text-azul mb-1">Teléfono</label>
        <input type="tel" id="telefono" name="telefono" placeholder="Tu número de teléfono" required autocomplete="tel" class="w-full px-4 py-2 border border-celeste/40 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-azul mb-1">Email</label>
        <input type="email" id="email" name="email" placeholder="Tu dirección de email" required autocomplete="email" class="w-full px-4 py-2 border border-celeste/40 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja" />
      </div>
      <div>
        <label for="mensaje" class="block text-sm font-medium text-azul mb-1">Mensaje</label>
        <textarea id="mensaje" name="mensaje" rows="4" placeholder="Escribe tu consulta aquí..." required minlength="10" autocomplete="off" class="w-full px-4 py-2 border border-celeste/40 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja"></textarea>
      </div>
      <button type="submit" class="mt-2 px-6 py-2 rounded bg-azul text-white font-semibold hover:bg-azul/90 transition-base focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja">Enviar</button>
    </form>
  </section>
</BaseLayout>
