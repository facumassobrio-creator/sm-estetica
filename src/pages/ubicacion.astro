---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site.js';
---
<BaseLayout title="Ubicación - SM Estética" description="Encuentra nuestra clínica en el mapa">
  <!-- Encabezado -->
  <section class="max-w-6xl mx-auto py-12 text-center fade-in">
    <h1 class="text-4xl md:text-5xl font-extrabold text-azul mb-2">Ubicación</h1>
    <p class="text-lg text-azul/80">Encontranos fácilmente en nuestro consultorio.</p>
  </section>

  <!-- Contenido principal -->
  <section class="max-w-6xl mx-auto py-12 grid grid-cols-1 md:grid-cols-2 gap-8 items-start fade-in">
    <div>
      <div class="bg-white rounded-xl border border-celeste/40 p-6 shadow slide-up">
        <h2 class="text-2xl font-semibold text-azul mb-2">Dirección</h2>
        <p class="text-text text-sm mb-4">{site.direccion}</p>
        <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.direccion)}`} target="_blank" rel="noopener" class="inline-block px-5 py-2 rounded border border-azul text-azul font-semibold hover:bg-celeste transition-base focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja">Abrir en Google Maps</a>
      </div>
    </div>
    <div class="flex justify-center">
      <div class="w-full aspect-video rounded-xl overflow-hidden shadow-inner slide-up">
        <iframe src={site.googleMapsEmbedUrl} class="w-full h-full" frameborder="0" allowfullscreen="" aria-hidden="false" tabindex="0"></iframe>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="max-w-3xl mx-auto py-12 text-center fade-in">
    <h3 class="text-xl font-bold text-azul mb-4">¿Listo para reservar?</h3>
    <a href={`https://wa.me/${site.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="btn btn-primary">Reservar por WhatsApp</a>
  </section>
</BaseLayout>
