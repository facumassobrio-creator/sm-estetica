---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site.js';

const success = Astro.url.searchParams.get('success');
const doctorPhotos = {
  'Dr. Sergio Manuel Martinez': '/dr-sergio.png',
  'Dr. José Manuel Martinez': '/dr-jose.png',
  'Dra. Romero Maria Florencia': '/dra-romero.png',
};
---

<BaseLayout title={site.brand.name} description={`Inicio de ${site.brand.name}, tu clínica premium de estética médica`}>
  {/* HERO */}
  <section id="inicio" class="anchor-section max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-8 py-12 fade-in">
    <div class="flex-1 md:basis-[55%] flex flex-col gap-4 items-start justify-center">
      <h1 class="sr-only">SM Estética Integral</h1>
      <img src="/logo-sm-estetica-v2.png" alt="SM Estética Integral" class="w-96 md:w-[34rem] lg:w-[38rem] h-auto mb-8 mx-auto md:mx-0" loading="eager" decoding="async" />
      <h2 class="text-lg md:text-xl text-azul/80 font-semibold mb-1">Odontología estética en Corrientes • Cirugía estética • Endodoncia</h2>
      <p class="text-base text-text mb-4">Tu bienestar y confianza con atención profesional en Corrientes.</p>
      <div class="flex gap-3 mt-2">
        <a href={`https://wa.me/${site.contact.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="btn btn-primary">Reservar por WhatsApp</a>
        <a href="#ubicacion" class="btn btn-secondary">Ver ubicación</a>
      </div>
    </div>
    <div class="flex-1 md:basis-[45%] flex items-center justify-center w-full md:w-auto">
      <div class="relative w-full max-w-sm h-72 sm:h-80 md:max-w-none md:w-full md:h-[30rem] lg:h-[34rem] rounded-xl shadow-inner overflow-hidden slide-up select-none">
        <img src="/hero.png" alt="SM Estetica Integral" class="w-full h-full object-cover" loading="eager" decoding="async" />
        <div class="absolute inset-0 bg-white/15"></div>
      </div>
    </div>
  </section>

  {/* SERVICIOS */}
  <section class="max-w-6xl mx-auto py-10 grid grid-cols-1 md:grid-cols-3 gap-8 fade-in">
    {[
      { title: 'Odontología', icon: '🦷', description: 'General, ortodoncia e implantes' },
      { title: 'Cirugía estética', icon: '💉', description: 'Procedimientos mini invasivos' },
      { title: 'Endodoncia', icon: '⚕️', description: 'Tratamientos de conducto' },
    ].map((servicio, i) => (
      <div data-key={servicio.title} class="bg-white rounded-xl shadow hover:shadow-lg transition-base p-8 flex flex-col items-center text-center gap-3 border border-celeste/40 group slide-up" style={{ animationDelay: `${i * 0.1 + 0.2}s` }}>
        <div class="text-4xl mb-2">{servicio.icon}</div>
        <h3 class="text-xl font-bold text-azul">{servicio.title}</h3>
        <p class="text-text text-sm">{servicio.description}</p>
      </div>
    ))}
  </section>

  {/* GALERÍA */}
  <section class="max-w-6xl mx-auto py-10 grid grid-cols-1 md:grid-cols-2 gap-6 fade-in">
    {[
      { src: '/jose con paciente.png', alt: 'Atención al paciente' },
      { src: '/herramientas.png', alt: 'Herramientas médicas' },
      { src: '/sergio escribiendo.png', alt: 'Doctor trabajando' },
      { src: '/quirofano.png', alt: 'Quirófano' },
    ].map((img) => (
      <div class="aspect-[4/3] rounded-xl shadow-inner hover:shadow-lg transition-base slide-up overflow-hidden">
        <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading="lazy" decoding="async" />
      </div>
    ))}
  </section>

  {/* CTA FINAL */}
  <section class="max-w-2xl mx-auto py-10 flex flex-col items-center gap-4 fade-in">
    <h3 class="text-xl font-bold text-azul">¿Listo para tu cambio?</h3>
    <a href={`https://wa.me/${site.contact.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="btn btn-primary">Reservar por WhatsApp</a>
  </section>

  {/* NOSOTROS */}
  <section id="nosotros" class="anchor-section max-w-6xl mx-auto py-12 text-center fade-in">
    <h2 class="text-4xl md:text-5xl font-extrabold text-azul mb-2">Nosotros</h2>
    <p class="text-lg text-azul/80">Profesionales y tecnología para tu bienestar</p>
  </section>

  <section class="max-w-6xl mx-auto py-12 grid grid-cols-1 md:grid-cols-2 gap-8 items-center fade-in">
    <div class="order-2 md:order-1 flex flex-col gap-4">
      <p class="text-text text-base leading-relaxed">En {site.brand.name} ofrecemos un enfoque completo en salud y estética integral en Corrientes, combinando experiencia médica, tecnología y atención personalizada.</p>
      <p class="text-text text-base leading-relaxed">Nuestro equipo está conformado por profesionales especializados en cirugía estética mini invasiva y odontología estética en Corrientes, abarcando tratamientos de ortodoncia, implantes y endodoncia bajo estándares clínicos elevados.</p>
      <p class="text-text text-base leading-relaxed">Nos enfocamos en brindar tratamientos estéticos en Corrientes con resultados naturales, seguros y adaptados a cada paciente, en un entorno pensado para tu comodidad, confianza y bienestar.</p>
    </div>
    <div class="order-1 md:order-2 flex justify-center">
      <div class="w-full aspect-[4/3] rounded-xl shadow-inner slide-up overflow-hidden">
        <img src="/equipo.png" alt="Equipo de doctores SM Estética Integral" class="w-full h-full object-cover" loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto py-12 fade-in">
    <h3 class="text-2xl font-bold text-azul mb-6 text-center">Valores</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        { icon: '🤝', text: 'Atención personalizada' },
        { icon: '📜', text: 'Profesionales certificados' },
        { icon: '🛡️', text: 'Tecnología y seguridad' },
      ].map((v, i) => (
        <div class="rounded-xl bg-white border border-celeste/40 p-6 flex flex-col items-center text-center gap-3 slide-up transition-base hover:shadow-lg" style={{ animationDelay: `${i * 0.1 + 0.2}s` }}>
          <div class="text-4xl">{v.icon}</div>
          <p class="text-text font-medium">{v.text}</p>
        </div>
      ))}
    </div>
  </section>

  {/* CONTACTO */}
  <section id="contacto" class="anchor-section max-w-6xl mx-auto py-12 text-center fade-in">
    <h2 class="text-4xl md:text-5xl font-extrabold text-azul mb-2">Contacto</h2>
    <p class="text-lg text-azul/80">Estamos aquí para ayudarte, escríbenos o visita nuestras redes.</p>
  </section>

  <section class="max-w-6xl mx-auto py-12 space-y-6 fade-in">
    <div class="bg-white rounded-xl border border-celeste/40 shadow-sm p-6 slide-up">
      <h3 class="text-3xl font-bold text-azul mb-1">Doctores</h3>
      <p class="text-text text-sm">Consultas directas con atención profesional en Corrientes para cada doctor.</p>
    </div>

    {site.professionals.map((doctor) => (
      <article class="bg-white rounded-xl border border-celeste/25 shadow-sm p-6 md:p-8 flex flex-col md:flex-row gap-4 items-center md:items-start">
        <div class="w-28 h-28 rounded-full overflow-hidden bg-gray-200 flex items-center justify-center text-sm font-semibold text-gray-500">
          <img
            src={doctorPhotos[doctor.name]}
            alt={doctor.name}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
            onerror="this.style.display='none'; this.parentElement.classList.add('bg-gray-200','flex','items-center','justify-center','text-sm','font-semibold','text-gray-500'); this.parentElement.appendChild(document.createTextNode('Foto'));"
          />
        </div>
        <div class="flex-1 space-y-2 text-left">
          <h4 class="text-2xl font-semibold text-azul">{doctor.name}</h4>
          <p class="text-text"><span class="font-semibold">Especialidad:</span> {doctor.specialty}</p>
          <p class="text-text"><span class="font-semibold">Teléfono:</span> {doctor.phone}</p>
          {doctor.email && <p class="text-text"><span class="font-semibold">Mail:</span> <a href={`mailto:${doctor.email}`} class="text-azul hover:text-naranja">{doctor.email}</a></p>}
          {doctor.instagram && <p class="text-text"><span class="font-semibold">Instagram:</span> <a href={`https://instagram.com/${doctor.instagram.replace('@','')}`} target="_blank" rel="noopener" class="text-azul hover:text-naranja">{doctor.instagram}</a></p>}
          <p class="text-text"><span class="font-semibold">Horarios:</span> {doctor.hours}</p>
          <a href={`https://wa.me/${doctor.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="btn btn-primary rounded-full mt-2 inline-flex items-center justify-center">Consultar</a>
        </div>
      </article>
    ))}
  </section>

  <section class="max-w-6xl mx-auto py-12 fade-in">
    <h3 class="text-2xl font-bold text-azul mb-4 text-center">Dejanos tu consulta</h3>
    {success === '1' && (
      <div class="max-w-md mx-auto mb-4 p-4 bg-green-100 border border-green-400 text-green-700 rounded">
        ✅ Consulta enviada correctamente. Nos comunicaremos a la brevedad.
      </div>
    )}
    <form action={site.form.endpoint} method="POST" class="max-w-md mx-auto flex flex-col gap-4 slide-up">
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" />
      <input type="hidden" name="_next" value="https://smesteticaintegral.com.ar/?success=1#contacto" />

      <div>
        <label for="nombre" class="block text-sm font-medium text-azul mb-1">Nombre</label>
        <input type="text" id="nombre" name="nombre" placeholder="Tu nombre completo" required autocomplete="name" class="w-full px-4 py-2 border border-celeste/40 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja" />
      </div>
      <div>
        <label for="telefono" class="block text-sm font-medium text-azul mb-1">Teléfono</label>
        <input type="tel" id="telefono" name="telefono" placeholder="Tu número de teléfono" required autocomplete="tel" class="w-full px-4 py-2 border border-celeste/40 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-azul mb-1">Email</label>
        <input type="email" id="email" name="email" placeholder="Tu dirección de email" required autocomplete="email" class="w-full px-4 py-2 border border-celeste/40 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja" />
      </div>
      <div>
        <label for="mensaje" class="block text-sm font-medium text-azul mb-1">Mensaje</label>
        <textarea id="mensaje" name="mensaje" rows="4" placeholder="Escribe tu consulta aquí..." required minlength="10" autocomplete="off" class="w-full px-4 py-2 border border-celeste/40 rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja"></textarea>
      </div>
      <button type="submit" class="mt-2 px-6 py-2 rounded bg-azul text-white font-semibold hover:bg-azul/90 transition-base focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja">Enviar</button>
    </form>
  </section>

  {/* UBICACION */}
  <section id="ubicacion" class="anchor-section max-w-6xl mx-auto py-12 text-center fade-in">
    <h2 class="text-4xl md:text-5xl font-extrabold text-azul mb-2">Ubicación</h2>
    <p class="text-lg text-azul/80">Encontranos fácilmente en nuestro consultorio.</p>
  </section>

  <section class="max-w-6xl mx-auto py-12 grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch fade-in">
    <div class="flex">
      <div class="bg-white rounded-xl border border-celeste/40 p-6 shadow slide-up flex flex-col justify-between w-full">
        <div>
          <h3 class="text-2xl font-semibold text-azul mb-2">Dirección</h3>
          <p class="text-text text-sm mb-4">{site.location.address}</p>
        </div>
        <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.location.address)}`} target="_blank" rel="noopener" class="inline-block px-5 py-2 rounded border border-azul text-azul font-semibold hover:bg-celeste transition-base focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja">Abrir en Google Maps</a>
      </div>
    </div>
    <div class="flex justify-center">
      <div class="w-full aspect-video rounded-xl overflow-hidden shadow-inner slide-up border-2 border-naranja">
        <iframe src={site.location.googleMapsEmbedUrl} class="w-full h-full" frameborder="0" allowfullscreen="" aria-hidden="false" tabindex="0"></iframe>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto py-12 text-center fade-in">
    <h3 class="text-xl font-bold text-azul mb-4">¿Listo para reservar?</h3>
    <a href={`https://wa.me/${site.contact.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="btn btn-primary">Reservar por WhatsApp</a>
  </section>
</BaseLayout>