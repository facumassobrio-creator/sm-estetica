---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site.js';
---
<BaseLayout title="Nosotros - SM Estética" description="Conoce al equipo profesional de SM Estética">
  <!-- Encabezado -->
  <section class="max-w-6xl mx-auto py-12 text-center fade-in">
    <h1 class="text-4xl md:text-5xl font-extrabold text-azul mb-2">Nosotros</h1>
    <p class="text-lg text-azul/80">Profesionales y tecnología para tu bienestar</p>
  </section>

  <!-- La clínica -->
  <section class="max-w-6xl mx-auto py-12 grid grid-cols-1 md:grid-cols-2 gap-8 items-center fade-in">
    <div class="order-2 md:order-1">
      <p class="text-text text-base leading-relaxed">En SM Estética brindamos atención integral con estándares médicos elevados. Nuestro espacio está diseñado para tu confort y seguridad.</p>
    </div>
    <div class="order-1 md:order-2 flex justify-center">
      <div class="w-full aspect-[4/3] bg-celeste flex items-center justify-center rounded-xl shadow-inner text-azul text-xl font-semibold slide-up select-none">Foto consultorio</div>
    </div>
  </section>

  <!-- Nuestro equipo -->
  <section class="max-w-6xl mx-auto py-12 fade-in">
    <h2 class="text-2xl font-bold text-azul mb-6 text-center">Nuestro equipo</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        { nombre: 'Dra. Nombre Apellido', especialidad: 'Odontología' },
        { nombre: 'Dra. Nombre Apellido', especialidad: 'Cirugía estética' },
        { nombre: 'Dra. Nombre Apellido', especialidad: 'Dermatología' },
      ].map((p, i) => (
        <div class="bg-white rounded-xl shadow hover:shadow-lg transition-base p-6 flex flex-col items-center text-center gap-3 border border-celeste/40 slide-up" style={{ animationDelay: `${i * 0.1 + 0.2}s` }}>
          <div class="w-24 h-24 bg-celeste rounded-full flex items-center justify-center text-azul text-xl font-semibold">Foto</div>
          <h3 class="text-lg font-semibold text-azul">{p.nombre}</h3>
          <p class="text-text text-sm">{p.especialidad}</p>
          <p class="text-text text-xs">Profesional especializado aquí.</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Valores -->
  <section class="max-w-6xl mx-auto py-12 fade-in">
    <h2 class="text-2xl font-bold text-azul mb-6 text-center">Valores</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {[
        { icon: '🤝', text: 'Atención personalizada' },
        { icon: '📜', text: 'Profesionales certificados' },
        { icon: '🛡️', text: 'Tecnología y seguridad' },
      ].map((v, i) => (
        <div class="rounded-xl bg-white border border-celeste/40 p-6 flex flex-col items-center text-center gap-3 slide-up transition-base hover:shadow-lg" style={{ animationDelay: `${i * 0.1 + 0.2}s` }}>
          <div class="text-4xl">{v.icon}</div>
          <p class="text-text font-medium">{v.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA final -->
  <section class="max-w-3xl mx-auto py-12 text-center fade-in">
    <h3 class="text-xl font-bold text-azul mb-4">Consultá con nosotros hoy mismo</h3>
    <a href={`https://wa.me/${site.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="px-6 py-2 rounded bg-naranja/90 text-white font-semibold shadow hover:bg-naranja transition-base focus:outline-none focus-visible:ring-2 focus-visible:ring-naranja text-base">Contactar por WhatsApp</a>
  </section>
</BaseLayout>
