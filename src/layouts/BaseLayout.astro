---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { site } from '../config/site.js';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
}

const {
  title = site.brand.seoTitle,
  description = '',
  keywords = site.brand.keywords,
}: Props = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description || site.brand.description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || site.brand.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.brand.siteName} />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description || site.brand.description} />

    <link rel="icon" href="/favicon-v2.png" type="image/png" />

    <!-- Schema.org MedicalBusiness (JSON-LD) -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      "name": "SM Estética Integral",
      "url": "https://smesteticaintegral.com.ar",
      "telephone": "+5493794321439",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Santa Fé 1238 1er piso",
        "addressLocality": "Corrientes",
        "addressCountry": "AR"
      },
      "openingHours": "Mo-Fr 16:00-20:00",
      "sameAs": [
        "https://instagram.com/smesteticaintegralctes"
      ]
    }
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-WHNPNJVZ');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WHNPNJVZ"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <Header />
    <main class="flex-1 pt-8 md:pt-12 px-4">
      <slot />
    </main>
    <Footer />
  </body>
</html>
